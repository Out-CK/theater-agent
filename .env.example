# Required
ANTHROPIC_API_KEY=your_anthropic_api_key_here
NIMBLE_API_KEY=your_nimble_api_key_here
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Optional — ticketing platforms (omit to skip that platform)
TICKETMASTER_API_KEY=your_ticketmaster_api_key_here
SEATGEEK_CLIENT_ID=your_seatgeek_client_id_here
SEATGEEK_CLIENT_SECRET=your_seatgeek_client_secret_here
EVENTBRITE_API_KEY=your_eventbrite_api_key_here
STUBHUB_CLIENT_ID=your_stubhub_client_id_here
STUBHUB_CLIENT_SECRET=your_stubhub_client_secret_here

# Optional
LOG_LEVEL=INFO
